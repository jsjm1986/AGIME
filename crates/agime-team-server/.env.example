# AGIME Team Server environment template
# Copy to .env and adjust as needed.

# Server
TEAM_SERVER_HOST=0.0.0.0
TEAM_SERVER_PORT=8080
RUST_LOG=agime_team_server=info,tower_http=debug

# Database (example: SQLite)
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite:///data/team.db?mode=rwc
DATABASE_MAX_CONNECTIONS=10

# Workspace
WORKSPACE_ROOT=./data/workspaces

# MCP task mode
TEAM_MCP_ENABLE_TASK_CALLS=true
MCP_TASK_TIMEOUT_SECS=600

# MCP elicitation in team-server sampling bridge
# false: do not advertise elicitation capability (recommended default)
# true: advertise capability, fallback action still applies when no interactive bridge is wired
TEAM_MCP_ENABLE_ELICITATION=false

# Fallback action when elicitation is requested but no interactive UI bridge exists:
# cancel | decline
TEAM_MCP_ELICITATION_DEFAULT_ACTION=cancel

