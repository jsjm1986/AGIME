# AGIME Team Server environment template
# Copy to .env and adjust as needed:  cp .env.example .env

# Server
TEAM_SERVER_HOST=0.0.0.0
TEAM_SERVER_PORT=8080
RUST_LOG=agime_team_server=info,tower_http=debug

# Database — MongoDB backend (production default, full feature set:
# agent routes, AI triggers, avatar governance). The bundled docker-compose
# provides a `mongo` service reachable at this URL.
DATABASE_TYPE=mongodb
DATABASE_URL=mongodb://mongo:27017
DATABASE_NAME=agime_team
DATABASE_MAX_CONNECTIONS=10

# Alternative: SQLite backend (single-node, feature-reduced — agent routes and
# AI triggers are MongoDB-only). Uncomment these and comment out the MongoDB
# block above to use it.
# DATABASE_TYPE=sqlite
# DATABASE_URL=sqlite:///data/team.db?mode=rwc

# Bootstrap admin — REQUIRED.
# The built-in default password is "agime"; docker-compose refuses to start
# unless BOOTSTRAP_ADMIN_PASSWORD is set here. Use a strong value.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-now

# Registration mode: open | approval | disabled
REGISTRATION_MODE=open

# Workspace
WORKSPACE_ROOT=./data/workspaces

# MCP task mode
TEAM_MCP_ENABLE_TASK_CALLS=true
MCP_TASK_TIMEOUT_SECS=600

# MCP elicitation in team-server sampling bridge
# false: do not advertise elicitation capability (recommended default)
# true: advertise capability, fallback action still applies when no interactive bridge is wired
TEAM_MCP_ENABLE_ELICITATION=false

# Fallback action when elicitation is requested but no interactive UI bridge exists:
# cancel | decline
TEAM_MCP_ELICITATION_DEFAULT_ACTION=cancel
